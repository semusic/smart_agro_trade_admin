rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if the user is an admin
    function isAdmin() {
      return request.auth != null && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Helper to check if a user is blocked
    function isNotBlocked() {
      return request.auth != null && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isBlocked == false;
    }

    // Users collection
    match /users/{userId} {
      // Admins can manage all users
      allow read, write: if isAdmin();
      
      // Users can read/write their own profiles if not blocked
      allow read, write: if request.auth != null && request.auth.uid == userId && isNotBlocked();
      
      // Public profile view (if needed)
      allow read: if request.auth != null;
    }

    // Listings collection
    match /listings/{listingId} {
      allow read: if request.auth != null;
      
      // Only admins can delete/flag/disable
      allow delete, update: if isAdmin();
      
      // Farmers can create and update their own listings if not blocked and approved
      allow create: if request.auth != null && 
                      get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'farmer' &&
                      get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isApproved == true &&
                      isNotBlocked();
                      
      allow update: if request.auth != null && 
                      request.resource.data.farmerId == request.auth.uid &&
                      isNotBlocked();
    }

    // Bids collection
    match /bids/{bidId} {
      allow read: if isAdmin() || (request.auth != null && (resource.data.buyerId == request.auth.uid || resource.data.farmerId == request.auth.uid));
      
      // Only admins can flag bids
      allow update: if isAdmin();
      
      // Approved buyers can bid
      allow create: if request.auth != null && 
                      get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'buyer' &&
                      get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isApproved == true &&
                      isNotBlocked();
    }

    // Disputes collection
    match /disputes/{disputeId} {
      allow read, write: if isAdmin();
      
      // Involved parties can read and create disputes
      allow read: if request.auth != null && (resource.data.buyerId == request.auth.uid || resource.data.farmerId == request.auth.uid);
      allow create: if request.auth != null && isNotBlocked();
    }

    // Flags collection (Admin ONLY)
    match /flags/{flagId} {
      allow read, write: if isAdmin();
    }

    // AI Config collection (Admin ONLY)
    match /ai_config/{configId} {
      allow read: if request.auth != null; // App reads this
      allow write: if isAdmin();
    }
  }
}
